{
    "name": "jardisport/validation",
    "description": "Validator, value validator, and validation result interfaces for object and field-level validation",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2"
    },
    "autoload": {
        "psr-4": {
            "JardisPort\\Validation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisPort\\Validation\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisPort/validation",
    "support": {
        "issues": "https://github.com/jardisPort/validation/issues",
        "email": "jardisCore@headgent.dev"
    },
    "keywords": [
        "validation",
        "interfaces",
        "JardisPort",
        "Headgent",
        "DDD"
    ]
}
